# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Email — dedicated Gmail account for COSA (e.g. cosa.baanbaan@gmail.com)
# Use a Gmail App Password (not the account password):
#   Google Account → Security → 2-Step Verification → App Passwords
# Gmail IMAP must be enabled:
#   Gmail Settings → See all settings → Forwarding and POP/IMAP → Enable IMAP
COSA_EMAIL_ADDRESS=cosa.baanbaan@gmail.com
COSA_EMAIL_IMAP_HOST=imap.gmail.com
COSA_EMAIL_IMAP_PORT=993
COSA_EMAIL_SMTP_HOST=smtp.gmail.com
COSA_EMAIL_SMTP_PORT=587
COSA_EMAIL_USERNAME=cosa.baanbaan@gmail.com
COSA_EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (16-char)

# Internal
COSA_DATA_DIR=./data
COSA_LOG_LEVEL=info
NODE_ENV=production

# Credential store — required for COSA to start.
# Used to derive the AES-256-GCM key that encrypts all stored credentials.
# Generate a strong value, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store this in your secrets manager or .env file (never commit it).
COSA_CREDENTIAL_KEY=change-me-to-a-strong-random-secret

# Communication mode — controls how COSA writes emails to the operator.
#
# simple (default): Plain business language. COSA says "your system is having trouble"
#   instead of "HTTP /health returned 200 degraded". No technical jargon. Recommended
#   for restaurant owners and managers who just want to know if things are running.
#
# advanced: Full technical detail. Includes SSH status, HTTP status codes, systemd
#   states, database metrics, error traces, and raw tool output. For technically
#   savvy operators or when diagnosing problems with a developer.
#
COSA_OPERATOR_MODE=simple
